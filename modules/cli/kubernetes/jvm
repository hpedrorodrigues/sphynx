#!/usr/bin/env bash

set -o errexit
set -o nounset
set -o pipefail

source "${SPHYNX_CLI_DIR}/.internal/all.sh"
source "${SPHYNX_NAMESPACE_DIR}/shared/shared.sh"
source "${SPHYNX_NAMESPACE_DIR}/core/jvm.sh"

##? Generate heap dumps and thread dumps from JVM processes running in Kubernetes pods
##?
##? Usage:
##?     jvm [<query>] [-l <selector>] [--namespace <name> | --all-namespaces] [--heapdump] [--threaddump] [--output-dir <path>] [--context <name>]
##?     jvm --namespace <name> --pod <name> --container <name> [--heapdump] [--threaddump] [--output-dir <path>] [--context <name>]
##?
##? Options:
##?     -l --selector <selector>  Selector (label query) to filter on
##?     -n --namespace <name>  The namespace scope for requests
##?     -A --all-namespaces  All namespaces
##?     -p --pod <name>  The pod name
##?     -c --container <name>  The container name
##?     --heapdump  Generate a heap dump
##?     --threaddump  Generate a thread dump
##?     --output-dir <path>  Local directory to store the dump file
##?     --context <name>  The name of the kubeconfig context to use
##?
##? Examples:
##?     jvm
##?     jvm --heapdump
##?     jvm kafka --threaddump
##?     jvm --selector app=kafka --heapdump --output-dir /tmp/dumps
##?     jvm --namespace kafka --pod kafka-0 --container kafka --threaddump
##?     jvm kafka --context staging

sx::parse_arguments "${@}"

readonly generate_heapdump="$(
  [ "${heapdump:-false}" = 'false' ] && [ "${threaddump:-false}" = 'false' ] \
    && echo 'true' \
    || echo "${heapdump:-false}"
)"

sx::k8s::jvm \
  "${query:-}" \
  "${selector:-}" \
  "${namespace:-}" \
  "${pod:-}" \
  "${container:-}" \
  "${generate_heapdump}" \
  "${threaddump:-false}" \
  "${output_dir:-}" \
  "${all_namespaces:-false}" \
  "${context:-}"
