#!/usr/bin/env bash

set -o errexit
set -o nounset
set -o pipefail

source "${SPHYNX_CLI_DIR}/.internal/all.sh"
source "${SPHYNX_NAMESPACE_DIR}/shared/shared.sh"
source "${SPHYNX_NAMESPACE_DIR}/core/debug.sh"

##? Debug cluster resources using interactive ephemeral containers
##?
##? Usage:
##?     debug [<query>] [-l <selector>] [--namespace <name> | --all-namespaces] [--image <image>] [--user <uid>] [--group <gid>] [--restricted] [--context <name>]
##?     debug --namespace <name> --pod <name> --container <name> [--image <image>] [--user <uid>] [--group <gid>] [--restricted] [--context <name>]
##?
##? Options:
##?     -l --selector <selector>  Selector (label query) to filter on
##?     -n --namespace <name>  The namespace scope for requests
##?     -A --all-namespaces  All namespaces
##?     -p --pod <name>  The pod name
##?     -c --container <name>  The container name
##?     --image <image>  Container image to use for debug container. [default: ghcr.io/hpedrorodrigues/debug]
##?     --user <uid>  Run debug container as this user ID
##?     --group <gid>  Run debug container as this group ID
##?     --restricted  Run debug container without elevated privileges (no root, no sysadmin profile)
##?     --context <name>  The name of the kubeconfig context to use
##?
##? Examples:
##?     debug --image busybox
##?     debug keycloak --image busybox
##?     debug --image busybox --all-namespaces
##?     debug --restricted
##?     debug --user 1000 --group 1000
##?     debug keycloak --context staging

sx::parse_arguments "${@}"

sx::k8s::debug \
  "${query:-}" \
  "${selector:-}" \
  "${namespace:-}" \
  "${pod:-}" \
  "${container:-}" \
  "${image:-}" \
  "${all_namespaces:-false}" \
  "${user:-}" \
  "${group:-}" \
  "${restricted:-false}" \
  "${context:-}"
