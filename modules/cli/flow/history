#!/usr/bin/env bash

set -o errexit
set -o nounset
set -o pipefail

source "${SPHYNX_CLI_DIR}/.internal/all.sh"
source "${SPHYNX_NAMESPACE_DIR}/shared/shared.sh"
source "${SPHYNX_NAMESPACE_DIR}/core/history.sh"

##? Print the publication history of a catalog specification
##?
##? Usage:
##?     history [<query>] [--captures | --collections | --materializations | --tests] [--models]
##?
##? Options:
##?     -c --captures  Only include captures in the picker
##?     --collections  Only include collections in the picker
##?     --materializations  Only include materializations in the picker
##?     --tests  Only include tests in the picker
##?     --models  Print the specification model of each publication as JSON
##?
##? Examples:
##?     history
##?     history acme
##?     history --captures
##?     history acme --tests
##?     history --collections --models

sx::parse_arguments "${@}"

sx::flow::history \
  "${query:-}" \
  "${models:-false}" \
  "${captures:-false}" \
  "${collections:-false}" \
  "${materializations:-false}" \
  "${tests:-false}"
